{
    "name": "yotudrive",
    "version": "1.1.0",
    "description": "Infinite Cloud Storage on YouTube",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "pack": "electron-builder --dir",
        "dist": "electron-builder"
    },
    "build": {
        "appId": "com.yotudrive.app",
        "productName": "YotuDrive",
        "directories": {
            "output": "release"
        },
        "files": [
            "main.js",
            "preload.js",
            "../app.py",
            "../requirements.txt",
            "../src/**/*",
            "../web/out/**/*"
        ],
        "extraResources": [
            {
                "from": "../bin",
                "to": "bin",
                "filter": [
                    "**/*"
                ]
            }
        ],
        "mac": {
            "category": "public.app-category.utilities",
            "target": [
                "dmg"
            ]
        },
        "win": {
            "target": [
                "nsis"
            ],
            "icon": "icon.ico"
        },
        "linux": {
            "target": [
                "AppImage"
            ]
        }
    },
    "dependencies": {},
    "devDependencies": {
        "electron": "^29.1.0",
        "electron-builder": "^24.13.3"
    }
}